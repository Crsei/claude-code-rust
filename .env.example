# cc-rust environment example
#
# Usage:
# 1. Copy this file to `.env`
# 2. Fill only the variables you actually use
# 3. Do not commit your real `.env`
#
# Loading order at startup:
#   1. ~/.cc-rust/.env
#   2. <exe-dir>/.env
#   3. <cwd>/.env
#
# Notes:
# - Set only one provider token/key in normal usage.
# - `CC_BACKEND=codex` forces the OpenAI Codex auth path.
# - If `OPENAI_CODEX_AUTH_TOKEN` is set, it overrides `/login 4` saved OAuth credentials.

# ---------------------------------------------------------------------------
# Core runtime
# ---------------------------------------------------------------------------

# Backend selection: native | codex
# Uncomment ONE of the lines below based on your auth method:
#   native — use ANTHROPIC_API_KEY, OAuth (/login 2|3), or keychain
#   codex  — use Codex OAuth (/login 4)
# CC_BACKEND=native
# CC_BACKEND=codex

# Legacy alias for backend selection.
# CLAUDE_BACKEND=native

# Optional model override.
# Examples:
#   claude-sonnet-4-20250514
#   gpt-4o
#   gpt-5.4
#   anthropic/claude-sonnet-4
# CLAUDE_MODEL=

# Verbose output: 1/true to enable.
# CLAUDE_VERBOSE=false

# Permission mode override: default | auto | bypass
# CLAUDE_PERMISSION_MODE=default

# Optional Anthropic base URL override.
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional Rust tracing level.
# Examples: error | warn | info | debug | trace
# RUST_LOG=warn

# ---------------------------------------------------------------------------
# Recommended auth options
# ---------------------------------------------------------------------------

# Anthropic API key.
ANTHROPIC_API_KEY=

# Anthropic external auth token.
# ANTHROPIC_AUTH_TOKEN=

# OpenAI Codex direct token.
# Used when CC_BACKEND=codex, or whenever the codex provider is selected.
# If set, this wins over OAuth credentials saved by `/login 4`.
# OPENAI_CODEX_AUTH_TOKEN=

# Optional overrides for the codex provider.
# OPENAI_CODEX_BASE_URL=https://chatgpt.com/backend-api
# OPENAI_CODEX_MODEL=gpt-5.4

# ---------------------------------------------------------------------------
# OpenAI Codex OAuth (`/login 4`)
# ---------------------------------------------------------------------------

# Required for the OAuth browser flow.
# OPENAI_CODEX_OAUTH_CLIENT_ID=

# Optional OAuth overrides.
# OPENAI_CODEX_OAUTH_AUTH_URL=https://auth.openai.com/authorize
# OPENAI_CODEX_OAUTH_TOKEN_URL=https://auth.openai.com/oauth/token
# OPENAI_CODEX_OAUTH_REDIRECT_URI=http://localhost:1455/callback
# OPENAI_CODEX_OAUTH_SCOPES=openid profile offline_access

# ---------------------------------------------------------------------------
# Other supported providers
# Fill at most one in normal usage unless you explicitly want auto-detection.
# Detection priority is defined in src/api/providers.rs.
# ---------------------------------------------------------------------------

# Azure OpenAI
# AZURE_API_KEY=
# AZURE_BASE_URL=https://YOUR-RESOURCE.openai.azure.com/openai/v1

# OpenAI
# OPENAI_API_KEY=

# Google Gemini
# GOOGLE_API_KEY=

# Groq
# GROQ_API_KEY=

# OpenRouter
# OPENROUTER_API_KEY=

# DeepSeek
# DEEPSEEK_API_KEY=

# Zhipu GLM
# ZHIPU_API_KEY=

# Qwen / DashScope
# DASHSCOPE_API_KEY=

# Moonshot / Kimi
# MOONSHOT_API_KEY=

# Baichuan
# BAICHUAN_API_KEY=

# MiniMax
# MINIMAX_API_KEY=

# Yi
# YI_API_KEY=

# SiliconFlow
# SILICONFLOW_API_KEY=

# StepFun
# STEPFUN_API_KEY=

# Spark
# SPARK_API_KEY=

# ---------------------------------------------------------------------------
# Web search tool
# ---------------------------------------------------------------------------

# Tavily search provider.
# TAVILY_API_KEY=

# Brave search provider.
# BRAVE_SEARCH_API_KEY=

# ---------------------------------------------------------------------------
# Pricing overrides
# USD per 1M tokens. Leave unset to use built-in pricing tables.
# ---------------------------------------------------------------------------

# MODEL_INPUT_PRICE=0.10
# MODEL_OUTPUT_PRICE=0.40

# ---------------------------------------------------------------------------
# Tool execution tuning
# ---------------------------------------------------------------------------

# Default and maximum shell timeout in milliseconds.
# BASH_DEFAULT_TIMEOUT_MS=30000
# BASH_MAX_TIMEOUT_MS=600000

# ---------------------------------------------------------------------------
# Optional feature flags
# ---------------------------------------------------------------------------

# Daemon / KAIROS
# FEATURE_KAIROS=0
# FEATURE_KAIROS_BRIEF=0
# FEATURE_KAIROS_CHANNELS=0
# FEATURE_KAIROS_PUSH_NOTIFICATION=0
# FEATURE_KAIROS_GITHUB_WEBHOOKS=0
# FEATURE_PROACTIVE=0

# Team memory
# FEATURE_TEAMMEM=0

# Subagent dashboard
# FEATURE_SUBAGENT_DASHBOARD=0
# FEATURE_SUBAGENT_DASHBOARD_OPEN=0

# ---------------------------------------------------------------------------
# UI helper
# ---------------------------------------------------------------------------

# Path to the Rust binary used by the UI launcher.
# CC_RUST_BINARY=F:\AIclassmanager\cc\rust\target\debug\claude-code-rs.exe

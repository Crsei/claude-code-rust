{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "customConditions": ["bun"]
  },
  "include": ["src"],
  "exclude": ["ink-terminal", "node_modules", "dist"]
}
